{
  "name": "@berenddeboer/nx-plugins",
  "description": "A collection of third-party Nx plugins based on https://github.com/codebrewlab/nx-plugins by Devin Kwon",
  "author": {
    "name": "Berend de Boer"
  },
  "license": "MIT",
  "homepage": "https://github.com/berenddeboer/nx-plugins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/berenddeboer/nx-plugins.git"
  },
  "scripts": {
    "nx": "nx",
    "lint-stage": "lint-staged",
    "commitlint": "commitlint",
    "is-ci": "is-ci",
    "test": "nx test nx-aws-cdk",
    "lint": "nx lint nx-aws-cdk",
    "e2e": "nx e2e",
    "format": "biome check --write --changed",
    "build:aws-cdk": "nx build nx-aws-cdk",
    "link:aws-cdk": "cd dist/packages/nx-aws-cdk && npm link",
    "test:sst": "nx test nx-sst",
    "build:sst": "nx build nx-sst",
    "link:sst": "cd dist/packages/nx-sst && npm link",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@nx/devkit": "22.7.2",
    "@nx/eslint": "22.7.2",
    "@nx/node": "22.7.2",
    "@swc/helpers": "0.5.21",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@jscutlery/semver": "^5.8.1",
    "@nx/jest": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/plugin": "22.7.2",
    "@nx/vite": "22.7.2",
    "@nx/vitest": "22.7.2",
    "@nx/workspace": "22.7.2",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.33",
    "@types/jest": "30.0.0",
    "@types/node": "24.10.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-util": "30.4.1",
    "jiti": "2.7.0",
    "lint-staged": "^17.0.5",
    "nx": "22.7.2",
    "prettier": "^3.8.3",
    "ts-jest": "29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{js,json,css,scss,md,ts,html,graphql}": [
      "biome check --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "nx",
      "oxc-resolver"
    ]
  }
}
